# API Express (catálogo e pedidos). Contexto: raiz do repositório (importa `src/` compartilhado).
FROM node:20-alpine
WORKDIR /app

COPY server/package.json server/package-lock.json ./server/
RUN cd server && npm ci

COPY src ./src
COPY server ./server

WORKDIR /app/server
ENV PORT=3031
EXPOSE 3031

CMD ["npx", "tsx", "src/index.ts"]
